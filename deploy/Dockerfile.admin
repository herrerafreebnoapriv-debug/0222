# 管理后台（admin）：使用 nginx 托管 admin-test-UI 静态资源
# 构建上下文为项目根目录，在 deploy 目录执行时使用: docker build -f deploy/Dockerfile.admin -t mop-admin .
FROM nginx:alpine

# 删除默认静态页，放入 MOP 管理后台
RUN rm -rf /usr/share/nginx/html/*

# 从项目根复制管理后台 UI（构建时需在仓库根执行或通过 context 指定，须包含 assets 目录）
COPY admin-test-UI/ /usr/share/nginx/html/

# 使用专用配置：/assets/ 不回退 index.html，缺失时返回 404 便于排查
COPY deploy/nginx-admin-default.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
