# 用户端网页（web）：使用 nginx 托管 app-test-UI 静态资源
# 构建上下文为项目根目录。构建：docker build -f deploy/Dockerfile.web -t mop-web .
FROM nginx:alpine

RUN rm -rf /usr/share/nginx/html/*
COPY app-test-UI/ /usr/share/nginx/html/

RUN echo 'server { \
  listen 80; \
  root /usr/share/nginx/html; \
  index index.html; \
  location / { try_files $uri $uri/ /index.html; } \
}' > /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
